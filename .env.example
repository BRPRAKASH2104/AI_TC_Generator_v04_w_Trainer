# AI Test Case Generator - Environment Variables Configuration
# Copy this file to .env and set your actual values
# IMPORTANT: Never commit the actual .env file to version control

# ============================================================================
# CORE APPLICATION SETTINGS
# ============================================================================

# AI model configuration
AI_TG_MODEL=llama3.1:8b
AI_TG_TEMPLATE=test_generation_v3_structured
AI_TG_MAX_CONCURRENT=4

# Ollama connection settings
AI_TG_OLLAMA_HOST=127.0.0.1
AI_TG_OLLAMA_PORT=11434
AI_TG_TIMEOUT=600
AI_TG_TEMPERATURE=0.0

# Application behavior
AI_TG_VERBOSE=false
AI_TG_DEBUG=false
AI_TG_PERFORMANCE=false
AI_TG_LOG_LEVEL=INFO

# Security settings
AI_TG_ENCRYPTION=false

# ============================================================================
# SECRETS AND AUTHENTICATION
# ============================================================================

# Ollama API credentials (if using secured Ollama instance)
AI_TG_OLLAMA_API_KEY=your_ollama_api_key_here

# External AI service credentials (for cloud-based AI models)
AI_TG_EXTERNAL_API_KEY=your_external_ai_api_key_here

# Database credentials (if using external database)
AI_TG_DATABASE_PASSWORD=your_database_password_here

# Encryption key for sensitive data (generate with: openssl rand -hex 32)
AI_TG_ENCRYPTION_KEY=your_encryption_key_here

# ============================================================================
# CLOUD SERVICE CREDENTIALS
# ============================================================================

# AWS credentials (for S3 storage, Lambda functions, etc.)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# Azure credentials (for Azure AI services, storage, etc.)
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_TENANT_ID=your_azure_tenant_id

# ============================================================================
# WEBHOOK AND INTEGRATION SECRETS
# ============================================================================

# Webhook validation secret (for incoming webhooks)
AI_TG_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub integration (for accessing private repositories, creating issues)
AI_TG_GITHUB_TOKEN=your_github_personal_access_token

# Slack integration (for notifications and bot features)
AI_TG_SLACK_TOKEN=your_slack_bot_token

# ============================================================================
# DEVELOPMENT AND TESTING
# ============================================================================

# Test environment settings
AI_TG_TEST_MODE=false
AI_TG_MOCK_AI_RESPONSES=false

# Performance testing
AI_TG_BENCHMARK_MODE=false
AI_TG_LOAD_TEST_CONCURRENT_USERS=10

# ============================================================================
# SECURITY BEST PRACTICES
# ============================================================================

# 1. Generate strong, unique secrets for each environment
# 2. Rotate secrets regularly (recommended: every 30-90 days)
# 3. Use environment-specific secrets (dev, staging, production)
# 4. Store secrets in secure secret management systems for production
# 5. Limit secret access to necessary personnel only
# 6. Monitor secret usage and access logs
# 7. Use encrypted storage for secrets at rest

# ============================================================================
# EXAMPLE SECRET GENERATION COMMANDS
# ============================================================================

# Generate encryption key:
# openssl rand -hex 32

# Generate webhook secret:
# openssl rand -hex 16

# Generate API token:
# openssl rand -base64 32

# ============================================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================================

# For production deployments, consider using:
# - AWS Secrets Manager
# - Azure Key Vault
# - HashiCorp Vault
# - Kubernetes Secrets
# - Docker Secrets
# - CI/CD pipeline secret management

# Environment variable precedence (highest to lowest):
# 1. CLI arguments
# 2. Environment variables (.env file)
# 3. Configuration file (YAML)
# 4. Default values

# ============================================================================
# DOCKER ENVIRONMENT
# ============================================================================

# If using Docker, you can pass environment variables using:
# docker run -e AI_TG_MODEL=llama3.1:8b --env-file .env ai-tc-generator

# Docker Compose example:
# environment:
#   - AI_TG_MODEL=${AI_TG_MODEL}
#   - AI_TG_OLLAMA_API_KEY=${AI_TG_OLLAMA_API_KEY}

# ============================================================================
# TROUBLESHOOTING
# ============================================================================

# To verify environment variables are loaded correctly:
# python -c "from src.config import ConfigManager; config = ConfigManager(); config.print_summary()"

# To check secrets status:
# python -c "from src.config import ConfigManager; import json; config = ConfigManager(); print(json.dumps(config.get_secrets_status(), indent=2))"

# To validate secrets for specific mode:
# python -c "from src.config import ConfigManager; config = ConfigManager(); print(config.validate_secrets_for_mode('cloud'))"