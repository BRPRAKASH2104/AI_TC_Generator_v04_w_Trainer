# =================================================================
# AI Test Case Generator - Test Generation Prompt Templates
# File: prompts/templates/test_generation.yaml
# Version: 1.1 - v002 Prompt with Test Technique Selection
# Last Updated: 2025-08-12
# =================================================================

metadata:
  version: "1.1"
  last_updated: "2025-08-12"
  maintainer: "Test Engineering Team"
  description: "Test generation prompt templates - v003 with selectable test design techniques"

# Template configuration
template_config:
  variable_format: "{variable_name}"
  encoding: "utf-8"
  line_endings: "unix"

# Main test generation prompts
test_generation_prompts:
  
  # Driver Information Default prompt - updated to include selectable test design techniques
  driver_information_default:
    name: "Driver Information Default Test Generation"
    description: "v002 prompt with selectable test design techniques"
    category: "general"
    tags: ["automotive", "default", "table-based", "configurable-technique"]
    
    variables:
      required: 
        - heading
        - requirement_id  
        - table_str
        - row_count
        - voltage_precondition
      optional:
        - info_str
        - interface_str
        - test_technique # <-- STEP 1: NEW VARIABLE
      defaults:
        info_str: "None"
        interface_str: "None"
        test_technique: "Decision Table Testing" # <-- STEP 1: NEW VARIABLE DEFAULT

    template: |
      You are an expert automotive test engineer. Your task is to write granular test cases by decomposing the logic within the PRIMARY REQUIREMENT, using all the provided context and the specified test technique.
      --- CONTEXTUAL INFORMATION ---
      ## FEATURE HEADING:
      {heading}
      ## ADDITIONAL INFORMATION NOTES:
      {info_str}
      ## SYSTEM INTERFACE DICTIONARY (Inputs/Outputs/Variables):
      {interface_str}
      
      # <-- STEP 2: NEW SECTION WITH TECHNIQUES FROM MARKDOWN -->
      ## AVAILABLE TEST DESIGN TECHNIQUES:
      - **Decision Table Testing:** Test combinations of inputs and their corresponding system outputs as defined in a logic table.
      - **Boundary Value Analysis (BVA):** Test at the edges or boundaries of equivalence partitions identified from the interface or requirements.
      - **Equivalence Partitioning:** Group inputs into classes that are expected to be processed similarly.
      - **State Transition Testing:** Design tests to check transitions between system states.
      - **Scenario-Based Testing:** Test end-to-end user scenarios.
      - **All-Pairs Testing (or Pairwise Testing):** Efficiently test all possible pairs of parameter values.
      - **Diagnostic Testing (UDS - ISO 14229 / OBD-II):** Verify diagnostic services and fault reporting.
      
      --- PRIMARY REQUIREMENT TO TEST ---
      **ID:** {requirement_id}
      **Logic Table Data:**
      {table_str}
      
      --- YOUR TASK ---
      # <-- STEP 3: UPDATED CONDITIONAL INSTRUCTIONS WITH POSITIVE/NEGATIVE TEST COVERAGE -->
      1.  Generate test cases based on the following specified technique: **{test_technique}**.
      2.  Use the context to understand terms. For example, use the System Interface Dictionary to understand what a signal like 'B_FWMSIG' means.
      3.  The `"summary_suffix"` for each test case must be a short, descriptive title for that specific test.
      4.  The `"action"` must always be "{voltage_precondition}".
      
      ## TEST CASE GENERATION RULES:
      
      ### **For 'Decision Table Testing':**
      **POSITIVE TEST CASES (Required):**
      - Create one positive test case for EACH data row in the table. Ensure all {row_count} rows are covered.
      - Use exact input/output combinations as specified in the logic table.
      - Format: `"data"` = numbered list of "Input" column values: "1) Set [Header Name] = [Value]"
      - Format: `"expected_result"` = "Verify [Header Name] = [Value]" (combining all outputs)
      - Mark with `"test_type": "positive"` in each test case
      
      **NEGATIVE TEST CASES (Required):**
      For each input parameter identified in the System Interface Dictionary:
      - Generate tests with **invalid values** (out of range, wrong type, null values)
      - Generate tests with **boundary violations** (below minimum, above maximum)
      - Generate tests with **conflicting input combinations** not in the logic table
      - Format: `"data"` = numbered list with invalid inputs: "1) Set [Header Name] = [Invalid Value]"
      - Format: `"expected_result"` = "Verify error handling: [Expected Error/Rejection Behavior]"
      - Mark with `"test_type": "negative"` in each test case
      
      ### **For 'Boundary Value Analysis':**
      **POSITIVE BOUNDARIES:**
      - Test valid boundary values (minimum valid, maximum valid, typical valid values)
      - Format: `"expected_result"` = "Verify [Header Name] = [Expected Valid Response]"
      - Mark with `"test_type": "positive"` 
      
      **NEGATIVE BOUNDARIES:**
      - Test invalid boundaries (below minimum-1, above maximum+1, invalid data types)
      - Format: `"expected_result"` = "Verify error handling: [Expected Rejection/Error Behavior]"
      - Mark with `"test_type": "negative"`
      
      ### **For 'Equivalence Partitioning':**
      **POSITIVE PARTITIONS:**
      - Test one representative value from each valid equivalence class
      - Mark with `"test_type": "positive"`
      
      **NEGATIVE PARTITIONS:**
      - Test one representative value from each invalid equivalence class
      - Test boundary violations between partitions
      - Mark with `"test_type": "negative"`
      
      ### **For 'State Transition Testing':**
      **POSITIVE TRANSITIONS:**
      - Test all valid state transitions as documented
      - Mark with `"test_type": "positive"`
      
      **NEGATIVE TRANSITIONS:**
      - Test invalid state transitions (forbidden/impossible transitions)
      - Test state transitions with invalid triggers/conditions
      - Mark with `"test_type": "negative"`
      
      ### **For 'Scenario-Based Testing':**
      **POSITIVE SCENARIOS:**
      - Test complete valid end-to-end user workflows
      - Mark with `"test_type": "positive"`
      
      **NEGATIVE SCENARIOS:**
      - Test scenarios with user errors, system failures, or invalid sequences
      - Mark with `"test_type": "negative"`
      
      ### **For 'Diagnostic Testing':**
      **POSITIVE DIAGNOSTICS:**
      - Test valid diagnostic requests with proper authentication
      - Mark with `"test_type": "positive"`
      
      **NEGATIVE DIAGNOSTICS:**
      - Test unauthorized diagnostic access attempts
      - Test malformed diagnostic requests
      - Test diagnostic requests during inappropriate system states
      - Mark with `"test_type": "negative"`
      
      ## CRITICAL REQUIREMENTS:
      5.  **MANDATORY**: Each test case JSON object MUST include `"test_type"` field with value "positive" or "negative"
      6.  **COVERAGE**: Generate BOTH positive AND negative test cases for comprehensive coverage
      7.  **CLARITY**: Make negative test case descriptions explicit about what error/rejection is expected
      8.  **AUTOMOTIVE SAFETY**: For safety-critical functions, emphasize negative tests for hazardous conditions
      9.  Your entire response MUST be a single, valid JSON object with a single key: `"test_cases"`
      10. Each test case must have: `"summary_suffix"`, `"action"`, `"data"`, `"expected_result"`, `"test_type"`

    validation:
      min_row_count: 1
      max_row_count: 500
      required_context: ["heading", "requirement_id"]

# Prompt selection rules for automatic template choice
prompt_selection:
  # Default fallback
  default_template: "driver_information_default"
  
  # Model-specific preferences
  model_preferences:
    "llama3.1:8b":
      preferred: ["driver_information_default"]
      avoid: []
    "deepseek-coder-v2:16b":
      preferred: ["driver_information_default"]
      avoid: []